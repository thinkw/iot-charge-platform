# IoT 充电平台 - 管理端 (iot-frontend) 环境配置示例
#
# 用法：复制本文件为 `.env` 或 `.env.local` 并按需修改
#   cp .env.example .env
# - `.env` / `.env.local` 不会被 git 跟踪（已在根 .gitignore 中排除）
# - Vite 默认会按 `.env.[mode].local` > `.env.[mode]` > `.env.local` > `.env` 优先级加载
# - 运行时通过 import.meta.env.VITE_XXX 访问

# 后端 HTTP 基础地址（axios 与 vite proxy 都使用）
VITE_API_BASE_URL=http://localhost:8080/api

# 大屏 WebSocket 基础地址（store 会自动追加 ?userId=xxx）
# 可使用 {{userId}} 占位；不提供时按 ?userId=xxx 追加
VITE_WS_DASHBOARD_URL=ws://localhost:8080/ws/charge
