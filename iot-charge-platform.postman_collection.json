  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 自动为需要认证的请求添加 Bearer Token",
          "const authHeader = pm.request.headers.find(h => h.key === 'Authorization');",
          "if (authHeader && authHeader.value === 'Bearer {{token}}') {",
          "    if (!pm.collectionVariables.get('token')) {",
          "        console.warn('⚠ Token未设置，请先执行「用户登录」接口');",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "stationId",
