                },
                "url": {
                  "raw": "{{baseUrl}}/api/reservation/create",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "reservation", "create"]
                },
                "description": "预约充电桩指定时段。\n\n请求体：\n- chargerId: 充电桩ID（必填）\n- stationId: 充电站ID（必填）\n- reserveDate: 预约日期 yyyy-MM-dd（必填）\n- startTime: 开始时间 HH:mm（必填）\n- endTime: 结束时间 HH:mm（必填）"
              },
              "response": []
