# IoT 充电平台 - 微信小程序端 (iot-miniapp) 环境配置示例
#
# 用法：复制本文件为 `.env` 或 `.env.local` 并填入真实配置
#   cp .env.example .env.local
# - `.env` / `.env.local` 不会被 git 跟踪（已在根 .gitignore 中排除）
# - 运行时由 Vite 编译时静态替换 import.meta.env.VITE_* 变量
# - 修改后需重新编译（npm run dev:mp-weixin 或 npm run build:mp-weixin）

# 微信小程序 AppID
VITE_WECHAT_APPID=your-wx-appid-here

# 后端 API 地址（开发环境默认 localhost，生产环境改为实际域名）
VITE_API_BASE_URL=http://localhost:8080/api

# WebSocket 地址（开发环境默认 localhost，生产环境改为实际域名）
VITE_WS_BASE_URL=ws://localhost:8080
